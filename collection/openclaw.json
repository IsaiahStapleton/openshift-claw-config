        "name": "Podling",
        "workspace": "~/.openclaw/workspace",
        "identity": {
          "name": "Podling"
        },
        "subagents": {
          "allowAgents": [
            "default",
            "meetings"
          ]
        }
      },
      {
        "id": "meetings",
