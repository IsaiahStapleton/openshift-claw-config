        },
        "anthropic-vertex/claude-sonnet-4-6": {
          "alias": "Claude Sonnet 4.6"
        }
      },
      "heartbeat": {
        "every": "24h",
        "model": "anthropic-vertex/claude-sonnet-4-6",
        "target": "none",
        "lightContext": true,
        "skipWhenBusy": true,
        "timeoutSeconds": 180,
        "activeHours": {
          "start": "22:55",
          "end": "23:30",
          "timezone": "America/New_York"
        }
      },
      "userTimezone": "America/New_York"
    },
    "list": [
