      "model": {
        "fallbacks": [
          "anthropic-vertex/claude-opus-4-8",
          "anthropic-vertex/claude-opus-4-7",
          "anthropic-vertex/claude-opus-4-6"
        ],
        "primary": "anthropic-vertex/claude-sonnet-4-6"
